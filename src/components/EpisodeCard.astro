---
interface Props {
  slug: string;
  title: string;
  episodeNumber: number;
  publishDate: Date;
  duration: string;
  description: string;
}

const { slug, title, episodeNumber, publishDate, duration, description } = Astro.props;

const formattedDate = publishDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="group border border-border rounded-xl p-6 hover:border-accent/50 transition-colors bg-surface/50">
  <div class="flex items-center gap-3 mb-3">
    <span class="text-xs font-mono text-accent bg-accent-dim px-2 py-1 rounded">
      EP {String(episodeNumber).padStart(3, '0')}
    </span>
    <span class="text-muted text-sm">{formattedDate}</span>
    <span class="text-muted/70 text-sm ml-auto">{duration}</span>
  </div>
  <h2 class="text-lg font-semibold text-fg group-hover:text-accent transition-colors mb-2">
    <a href={`/episodes/${slug}`}>{title}</a>
  </h2>
  <p class="text-muted text-sm line-clamp-2">{description}</p>
  <a
    href={`/episodes/${slug}`}
    class="inline-flex items-center gap-1 mt-4 text-sm text-accent hover:text-accent-hover font-medium transition-colors"
  >
    Show notes
    <svg viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4" aria-hidden="true">
      <path fill-rule="evenodd" d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z" clip-rule="evenodd" />
    </svg>
  </a>
</article>
