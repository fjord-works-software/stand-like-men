---
import SocialLinks from './SocialLinks.astro';
---

<footer class="border-t border-border mt-16 bg-surface/50">
  <div class="max-w-5xl mx-auto px-6 py-10 flex flex-col sm:flex-row items-center justify-between gap-6">
    <div class="text-center sm:text-left">
      <p class="font-semibold text-fg">Stand Like Men Podcast</p>
      <p class="text-muted text-sm mt-1">Hosted by Daniel Chalenburg &amp; Logan Ingram</p>
    </div>
    <SocialLinks />
    <div class="text-center sm:text-right">
      <p class="text-muted/60 text-xs">&copy; {new Date().getFullYear()} Stand Like Men</p>
      <a href="https://fjordworkssoftware.com" target="_blank" rel="noopener noreferrer" class="text-muted/40 text-xs hover:text-accent transition-colors">
        Built by Fjord Works Software LLC
      </a>
    </div>
  </div>
</footer>
