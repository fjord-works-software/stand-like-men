---
interface Props {
  vertical?: boolean;
  class?: string;
}

const { vertical = false, class: className = '' } = Astro.props;

const links = [
  {
    name: 'Apple Podcasts',
    href: 'https://podcasts.apple.com',
    color: 'hover:text-purple-500',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6" aria-hidden="true"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm0 2.182a9.818 9.818 0 1 1 0 19.636A9.818 9.818 0 0 1 12 2.182zm0 3.272a6.545 6.545 0 1 0 0 13.09 6.545 6.545 0 0 0 0-13.09zm0 1.637a4.909 4.909 0 1 1 0 9.818 4.909 4.909 0 0 1 0-9.818zm0 1.636a3.273 3.273 0 1 0 0 6.546 3.273 3.273 0 0 0 0-6.546zm-.818 1.527a1.636 1.636 0 1 1 1.636 1.636 1.636 1.636 0 0 1-1.636-1.636zm.818-.655a.818.818 0 1 0 0 1.636.818.818 0 0 0 0-1.636z"/></svg>`,
  },
  {
    name: 'Spotify',
    href: 'https://open.spotify.com',
    color: 'hover:text-green-500',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6" aria-hidden="true"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>`,
  },
  {
    name: 'YouTube',
    href: 'https://youtube.com',
    color: 'hover:text-red-500',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6" aria-hidden="true"><path d="M23.495 6.205a3.007 3.007 0 0 0-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 0 0 .527 6.205a31.247 31.247 0 0 0-.522 5.805 31.247 31.247 0 0 0 .522 5.783 3.007 3.007 0 0 0 2.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 0 0 2.088-2.088 31.247 31.247 0 0 0 .5-5.783 31.247 31.247 0 0 0-.5-5.805zM9.609 15.601V8.408l6.264 3.602z"/></svg>`,
  },
  {
    name: 'Facebook',
    href: 'https://facebook.com',
    color: 'hover:text-blue-500',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>`,
  },
];
---

<div class:list={['flex gap-4', vertical ? 'flex-col' : 'flex-row items-center', className]}>
  {links.map(({ name, href, color, icon }) => (
    <a
      href={href}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={name}
      class:list={['text-muted transition-colors', color]}
    >
      <Fragment set:html={icon} />
    </a>
  ))}
</div>
