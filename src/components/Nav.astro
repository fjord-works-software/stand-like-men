---
import ThemeToggle from './ThemeToggle.astro';

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/episodes', label: 'Episodes' },
  { href: '/blog', label: 'Blog' },
  { href: '/hosts/daniel', label: 'Daniel' },
  { href: '/hosts/logan', label: 'Logan' },
];

const currentPath = Astro.url.pathname;
---

<header class="border-b border-border bg-bg/95 backdrop-blur sticky top-0 z-50">
  <nav class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between gap-4">
    <a href="/" class="text-xl font-bold tracking-tight text-fg hover:text-accent transition-colors shrink-0">
      Stand Like Men
    </a>
    <ul class="flex items-center gap-5 text-sm font-medium">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class={`transition-colors hover:text-accent ${currentPath === href ? 'text-accent' : 'text-muted'}`}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
    <ThemeToggle />
  </nav>
</header>
