---
import BaseLayout from '../layouts/BaseLayout.astro';
import SocialLinks from '../components/SocialLinks.astro';
import EpisodeCard from '../components/EpisodeCard.astro';
import { getCollection } from 'astro:content';

const episodes = (await getCollection('episodes'))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);
---

<BaseLayout title="Home">
  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-6 py-20 text-center">
    <div class="inline-block bg-[#0c0c0c] rounded-2xl p-6 mb-8 shadow-xl">
      <img
        src={`${import.meta.env.BASE_URL}images/StandLikeMenLogo.webp`}
        alt="Stand Like Men Podcast"
        class="w-64 sm:w-72 max-w-full"
      />
    </div>
    <p class="text-muted text-xl max-w-2xl mx-auto mb-10">
      Honest conversations about faith, purpose, brotherhood, and what it means to be a man worth following.
      Hosted by Daniel Chalenburg and Logan Ingram.
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-12">
      <a
        href={`${import.meta.env.BASE_URL}episodes`}
        class="px-8 py-3 bg-accent text-white font-bold rounded-lg hover:bg-accent-hover transition-colors"
      >
        Listen Now
      </a>
    </div>
    <SocialLinks class="justify-center" />
  </section>

  <!-- Latest Episodes -->
  <section class="max-w-5xl mx-auto px-6 pb-20">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl font-bold text-fg">Latest Episodes</h2>
      <a href="/episodes" class="text-sm text-accent hover:text-accent-hover font-medium transition-colors">
        All episodes &rarr;
      </a>
    </div>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {episodes.map((ep) => (
        <EpisodeCard
          slug={ep.id}
          title={ep.data.title}
          episodeNumber={ep.data.episodeNumber}
          publishDate={ep.data.publishDate}
          duration={ep.data.duration}
          description={ep.data.description}
        />
      ))}
    </div>
  </section>

  <!-- Hosts -->
  <section class="border-t border-border py-20">
    <div class="max-w-5xl mx-auto px-6 text-center">
      <h2 class="text-2xl font-bold text-fg mb-10">Meet the Hosts</h2>
      <div class="flex flex-col sm:flex-row gap-8 justify-center">
        {(['daniel', 'logan'] as const).map((slug) => (
          <a
            href={`${import.meta.env.BASE_URL}hosts/${slug}`}
            class="group flex-1 max-w-xs mx-auto border border-border rounded-xl p-8 hover:border-accent/50 transition-colors bg-surface/50"
          >
            <div class="w-20 h-20 rounded-full bg-border mx-auto mb-4" />
            <p class="font-semibold text-fg group-hover:text-accent transition-colors">
              {slug === 'daniel' ? 'Daniel Chalenburg' : 'Logan Ingram'}
            </p>
            <p class="text-muted text-sm mt-1">Co-host</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
