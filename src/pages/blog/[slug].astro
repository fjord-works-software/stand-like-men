---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts
    .filter((p) => !p.data.draft)
    .map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const authorNames = { daniel: 'Daniel Chalenburg', logan: 'Logan Ingram' };

const formattedDate = post.data.publishDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={post.data.title} description={post.data.excerpt}>
  <article class="max-w-3xl mx-auto px-6 py-16 bg-surface/50 rounded-2xl my-8">
    <a href={`${import.meta.env.BASE_URL}blog`} class="text-sm text-muted hover:text-accent transition-colors mb-8 inline-block">
      &larr; All articles
    </a>

    <div class="flex items-center gap-3 mb-4 text-sm text-muted">
      <span>{formattedDate}</span>
      <span>&middot;</span>
      <a href={`${import.meta.env.BASE_URL}hosts/${post.data.author}`} class="hover:text-accent transition-colors">
        {authorNames[post.data.author]}
      </a>
    </div>

    <h1 class="text-4xl font-extrabold text-fg mb-6">{post.data.title}</h1>
    <p class="text-muted text-lg mb-10 border-l-2 border-accent pl-4">{post.data.excerpt}</p>

    <div class="prose max-w-none">
      <Content />
    </div>
  </article>
</BaseLayout>
