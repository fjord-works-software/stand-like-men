---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<BaseLayout title="Blog" description="Articles and reflections from the Stand Like Men Podcast.">
  <div class="max-w-5xl mx-auto px-6 py-16">
    <h1 class="text-4xl font-extrabold text-fg mb-2">Blog</h1>
    <p class="text-muted mb-10">{posts.length} article{posts.length !== 1 ? 's' : ''}</p>
    <div class="grid gap-4 sm:grid-cols-2">
      {posts.map((post) => (
        <BlogCard
          slug={post.id}
          title={post.data.title}
          publishDate={post.data.publishDate}
          author={post.data.author}
          excerpt={post.data.excerpt}
        />
      ))}
    </div>
  </div>
</BaseLayout>
